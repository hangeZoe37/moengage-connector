{
  "info": {
    "name": "MoEngage SPARC Connector",
    "description": "Postman collection for testing the MoEngage-SPARC RCS Connector.\n\nFollowing MoEngage Official Onboarding Documentation for RCS Providers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "bearer_token",
      "value": "YOUR_BEARER_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Inbound Send (MoEngage -> Connector)",
      "item": [
        {
          "name": "TEXT Message (with parameters)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n \"messages\":[\n    {\n      \"destination\": \"+918512839790\",\n      \"callback_data\": \"cb_text_001\",\n      \"fallback_order\": [\"RCS\",\"SMS\"],\n      \"rcs\": {\n          \"bot_id\": \"test_bot_id\",\n          \"template_id\": \"welcome_text_01\",\n          \"message_content\": {\n                     \"type\": \"TEXT\",\n                     \"data\": {\n                        \"text\": \"Welcome John to MoEngage!\",\n                        \"parameters\": {\n                           \"name\": \"John\",\n                           \"company\": \"Moengage\"\n                        }\n                     }\n          }\n      }\n    }\n ]\n}"
            },
            "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
          }
        },
        {
          "name": "CARD Message (Vertical/Indian Format)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n \"messages\":[\n    {\n      \"destination\": \"+918512839790\",\n      \"callback_data\": \"cb_card_001\",\n      \"fallback_order\": [\"RCS\"],\n      \"rcs\": {\n          \"bot_id\": \"test_bot_id\",\n          \"template_id\": \"card_template_01\",\n          \"message_content\": {\n                     \"type\": \"CARD\",\n                     \"data\": {\n                        \"media\": {\n                           \"media_url\": \"https://img.freepik.com/free-photo/vibrant-colors-nature-close-up-generative-ai_188544-9121.jpg\",\n                           \"content_type\": \"IMAGE\"\n                        },\n                        \"title\": \"Welcome John to Moengage\",\n                        \"description\": \"John is happily welcomed to Moengage team\",\n                        \"orientation\": \"VERTICAL\",\n                        \"height\": \"MEDIUM\",\n                        \"parameters\": {\n                           \"name\": \"John\",\n                           \"team\": \"Product\"\n                        }\n                     },\n                     \"suggestions\": [\n                        {\n                           \"type\": \"REPLY\",\n                           \"text\": \"STOP Messaging\",\n                           \"postback_data\": \"STOP\"\n                        }\n                     ]\n          }\n      }\n    }\n ]\n}"
            },
            "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
          }
        },
        {
          "name": "MEDIA Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n \"messages\":[\n    {\n      \"destination\": \"+918512839790\",\n      \"callback_data\": \"cb_media_001\",\n      \"fallback_order\": [\"RCS\"],\n      \"rcs\": {\n          \"bot_id\": \"test_bot_id\",\n          \"template_id\": \"media_template_01\",\n          \"message_content\": {\n                     \"type\": \"MEDIA\",\n                     \"data\": {\n                        \"media_url\": \"https://www.w3schools.com/html/mov_bbb.mp4\",\n                        \"content_type\": \"VIDEO\"\n                     }\n          }\n      }\n    }\n ]\n}"
            },
            "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
          }
        },
        {
          "name": "Suggestion Types",
          "item": [
            {
              "name": "OPEN_URL Suggestion",
              "request": {
                "method": "POST",
                "header": [ { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" } ],
                "body": { "mode": "raw", "raw": "{\n \"messages\":[ {\n  \"destination\": \"+918512839790\",\n  \"callback_data\": \"cb_suggest_url\",\n  \"rcs\": {\n   \"bot_id\": \"bot1\", \"template_id\": \"t1\",\n   \"message_content\": {\n    \"type\": \"TEXT\", \"data\": { \"text\": \"Check our site\" },\n    \"suggestions\": [ {\n     \"type\": \"OPEN_URL\", \"text\": \"Visit Site\", \"postback_data\": \"visit_site\", \"url\": \"https://moengage.com\"\n    } ]\n   }\n  }\n } ]\n}" },
                "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
              }
            },
