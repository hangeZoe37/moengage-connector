                "header": [ { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" } ],
                "body": { "mode": "raw", "raw": "{\n \"messages\":[ {\n  \"destination\": \"+918512839790\",\n  \"callback_data\": \"cb_suggest_dial\",\n  \"rcs\": {\n   \"bot_id\": \"bot1\", \"template_id\": \"t1\",\n   \"message_content\": {\n    \"type\": \"TEXT\", \"data\": { \"text\": \"Call Support\" },\n    \"suggestions\": [ {\n     \"type\": \"DIAL_PHONE\", \"text\": \"Call Now\", \"postback_data\": \"call_support\", \"phone\": \"+910000000000\"\n    } ]\n   }\n  }\n } ]\n}" },
