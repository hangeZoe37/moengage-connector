            {
              "name": "SHOW_LOCATION Suggestion",
              "request": {
                "method": "POST",
                "header": [ { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" } ],
                "body": { "mode": "raw", "raw": "{\n \"messages\":[ {\n  \"destination\": \"+918512839790\",\n  \"callback_data\": \"cb_suggest_loc\",\n  \"rcs\": {\n   \"bot_id\": \"bot1\", \"template_id\": \"t1\",\n   \"message_content\": {\n    \"type\": \"TEXT\", \"data\": { \"text\": \"Store Location\" },\n    \"suggestions\": [ {\n     \"type\": \"SHOW_LOCATION\", \"text\": \"Find Us\", \"postback_data\": \"store_loc\", \"latitude\": \"12.9716\", \"longitude\": \"77.5946\", \"label\": \"MoEngage Bangalore\"\n    } ]\n   }\n  }\n } ]\n}" },
                "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
              }
            },
            {
              "name": "CREATE_CAL_EVENT Suggestion",
              "request": {
                "method": "POST",
                "header": [ { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" } ],
                "body": { "mode": "raw", "raw": "{\n \"messages\":[ {\n  \"destination\": \"+918512839790\",\n  \"callback_data\": \"cb_suggest_cal\",\n  \"rcs\": {\n   \"bot_id\": \"bot1\", \"template_id\": \"t1\",\n   \"message_content\": {\n    \"type\": \"TEXT\", \"data\": { \"text\": \"Book Meeting\" },\n    \"suggestions\": [ {\n     \"type\": \"CREATE_CAL_EVENT\", \"text\": \"Add to Calendar\", \"postback_data\": \"add_cal\", \"start_time\": \"2026-04-30T10:00:00Z\", \"end_time\": \"2026-04-30T11:00:00Z\", \"title\": \"Sales Call\", \"description\": \"Demo of MoEngage RCS Connector\"\n    } ]\n   }\n  }\n } ]\n}" },
                "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
              }
            }
          ]
        },
        {
          "name": "Bulk Send (Multi-message)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authentication", "value": "Bearer {{bearer_token}}", "type": "text" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n \"messages\":[\n    {\n      \"destination\": \"+918512839790\",\n      \"callback_data\": \"bulk_01_userA\",\n      \"rcs\": {\n          \"bot_id\": \"botA\",\n          \"template_id\": \"welcome\",\n          \"message_content\": { \"type\": \"TEXT\", \"data\": { \"text\": \"Msg A\" } }\n      }\n    },\n    {\n      \"destination\": \"+918512839791\",\n      \"callback_data\": \"bulk_01_userB\",\n      \"rcs\": {\n          \"bot_id\": \"botB\",\n          \"template_id\": \"welcome\",\n          \"message_content\": { \"type\": \"TEXT\", \"data\": { \"text\": \"Msg B\" } }\n      }\n    }\n ]\n}"
            },
            "url": { "raw": "{{base_url}}/integrations/moengage/rcs/send", "host": [ "{{base_url}}" ], "path": [ "integrations", "moengage", "rcs", "send" ] }
          }
        }
      ]
    },
