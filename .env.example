# Server
PORT=3000
NODE_ENV=development          # development | production

# ── SPARC RCS API ──────────────────────────────────────────
SPARC_API_BASE_URL=https://your-sparc-backend/backend/api/v2
# Default SPARC credentials (per-client credentials are stored in the clients DB table)
SPARC_SERVICE_ACCOUNT=default_account
SPARC_API_PASSWORD=default_password

# ── SPARC SMS API (separate auth + base URL from RCS) ──────
SPARC_SMS_API_BASE_URL=https://pgapi.sparc.smartping.io/fe
SPARC_SMS_USERNAME=
SPARC_SMS_PASSWORD=

# ── Webhooks ───────────────────────────────────────────────
# SPARC calls ONE URL for ALL events (delivered, read, failed, sent).
# Set this to YOUR server's public URL that SPARC will POST events to.
SPARC_WEBHOOK_URL=https://your-connector.com/sparc/webhook

# ── MoEngage DLR Callback URL ──────────────────────────────
MOENGAGE_DLR_URL=https://api-0x.moengage.com/rcs/dlr/<vendor_name>

# ─── Database (MySQL 8) ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME_ADMIN=sparc_admin
DB_NAME_MOE=sparc_moengage_db
DB_NAME_CT=sparc_clevertap_db
DB_NAME_WE=sparc_webengage_db
DB_USER=sparc_connector
DB_PASSWORD=your_db_password
DB_POOL_SIZE=20              # 20 per process; multiply by PM2 instances for total connections

# ── Authentication ─────────────────────────────────────────
# Secret key used for signing JWT tokens
JWT_SECRET=generate_a_random_32_char_secret_string

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info               # error | warn | info | debug

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000   # 1 minute window
RATE_LIMIT_MAX=500            # max requests per window per IP
