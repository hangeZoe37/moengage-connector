# Server
PORT=3000
NODE_ENV=development          # development | production

# SPARC API
SPARC_API_BASE_URL=https://your-sparc-backend/backend/api/v2
# Note: per-workspace SPARC credentials are stored in workspace_tokens DB table
# These are the default/fallback SPARC credentials if not per-workspace
SPARC_SERVICE_ACCOUNT=default_account
SPARC_API_PASSWORD=default_password

# Webhooks
SPARC_DLR_WEBHOOK_URL=https://your-connector.com/sparc/dlr
SPARC_INTERACTION_WEBHOOK_URL=https://your-connector.com/sparc/interaction

# MoEngage (default — per-workspace URL is in workspace_tokens table)
MOENGAGE_DLR_URL=https://api-0x.moengage.com/rcs/dlr/<vendor name>

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sparc_moengage
DB_USER=sparc_connector
DB_PASSWORD=your_db_password
DB_POOL_SIZE=10

# Logging
LOG_LEVEL=info               # error | warn | info | debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500
